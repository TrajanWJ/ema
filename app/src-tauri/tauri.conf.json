{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "EMA",
  "version": "0.2.0",
  "identifier": "app.ema.executive",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "launchpad",
        "title": "EMA",
        "width": 900,
        "height": 650,
        "minWidth": 700,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "shortDescription": "Executive Memory Assistant",
    "longDescription": "EMA is a local-first executive assistant that helps you manage context, memory, and workflows across multiple AI models. Runs entirely on your own hardware with optional multi-node mesh distribution."
  }
}
