    "./json": "./dist/tokens.json",
    "./ts": "./dist/tokens.ts"
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "node build.ts",
    "typecheck": "tsc --noEmit"
  }
}
