{
  "name": "@ema/tokens",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "EMA design tokens — ported from the old Elixir+Tauri build. Non-negotiable hex values from SELF-POLLINATION-FINDINGS Appendix A.8.",
  "main": "dist/tokens.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
