{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2023",
    "useDefineForClassFields": true,
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "types": ["vite/client"],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@ema/glass": ["../../shared/glass/src/index.ts"],
      "@ema/tokens": ["../../shared/tokens/src/index.ts"],
      "@ema/tokens/css": ["../../shared/tokens/dist/tokens.css"],
      "@ema/glass/styles/reset.css": ["../../shared/glass/src/styles/reset.css"],
      "@ema/glass/styles/keyframes.css": ["../../shared/glass/src/styles/keyframes.css"]
    }
  },
  "include": [
    "src",
    "../../shared/glass/src/**/*.ts",
    "../../shared/glass/src/**/*.tsx",
    "../../shared/glass/src/css-modules.d.ts",
    "../../shared/tokens/src/**/*.ts"
  ]
}
