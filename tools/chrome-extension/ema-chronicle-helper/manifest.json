{
  "manifest_version": 3,
  "name": "EMA Chronicle Helper",
  "version": "0.1.0",
  "description": "Capture ChatGPT and Claude browser conversations into EMA Chronicle.",
  "permissions": [
    "activeTab",
    "downloads",
    "storage",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "http://127.0.0.1:4488/*",
    "http://localhost:4488/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*"
  ],
  "action": {
    "default_title": "EMA Chronicle Helper",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
