# ── exec (executions) ────────────────────────────────────────────────────────

def cmd_exec_list(client, args):
    params = {}
    if args.status:
        params["status"] = args.status
    if args.project:
        params["project_slug"] = args.project
    result = client.get("/api/executions", params=params or None)
    executions = result.get("executions", []) if isinstance(result, dict) else result
    if args.limit:
        executions = executions[:args.limit]
    if USE_JSON:
        out_json(executions)
        return
    if not executions:
        out("No executions found.")
        return
    rows = []
    for e in executions:
        status = e.get("status", "?")
        status_icon = {"completed": "✓", "running": "▶", "failed": "✗", "created": "○"}.get(status, "·")
        rows.append([
            e.get("id", "?")[:12],
            f"{status_icon} {status}"[:11],
            (e.get("mode") or "?")[:10],
            (e.get("project_slug") or "—")[:12],
            (e.get("title") or e.get("objective", "?"))[:35],
            fmt_time(e.get("inserted_at")),
        ])
    table(rows, ["ID", "STATUS", "MODE", "PROJECT", "TITLE", "AGE"],
          [14, 12, 11, 14, 37, 12])


def cmd_exec_get(client, args):
    result = client.get(f"/api/executions/{args.exec_id}")
    if USE_JSON:
        out_json(result)
        return
    e = result if "id" in result else result.get("execution", result)
    out(f"\nExecution: {e.get('id')}")
    out(f"  Title:     {e.get('title', '—')}")
    out(f"  Status:    {e.get('status')}")
    out(f"  Mode:      {e.get('mode')}")
    out(f"  Project:   {e.get('project_slug', '—')}")
    out(f"  Created:   {fmt_time(e.get('inserted_at'))}")
    if e.get("completed_at"):
        out(f"  Completed: {fmt_time(e.get('completed_at'))}")
    if e.get("objective"):
        out(f"\n  Objective:\n    {e['objective'][:300]}")
    meta = e.get("metadata") or {}
    if meta.get("result_summary"):
        out(f"\n  Result:\n    {meta['result_summary'][:500]}")
    if e.get("result_path"):
        out(f"\n  Result path: {e['result_path']}")


def cmd_exec_create(client, args):
    objective = " ".join(args.objective) if isinstance(args.objective, list) else args.objective
    payload = {"objective": objective, "mode": args.mode or "research"}
    if args.title:
        payload["title"] = args.title
    if args.project:
        payload["project_slug"] = args.project
    result = client.post("/api/executions", payload)
    if USE_JSON:
        out_json(result)
        return
    e = result.get("execution", result)
    out(f"Created: {e.get('id', '?')} | mode: {e.get('mode')} | status: {e.get('status')}")


