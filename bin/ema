# ── watch (live dashboard) ───────────────────────────────────────────────────

import time


def cmd_watch(client, args):
    """Live dashboard — polls EMA and displays updates. Ctrl+C to exit."""
    interval = args.interval or 10
    channel = args.channel or "all"

    def fetch_section(path, fallback="unavailable"):
        try:
            return client.get(path)
        except (SystemExit, Exception):
            return None

    def render():
        lines = []
        from datetime import timezone
        now = datetime.now(timezone.utc).strftime("%H:%M:%S UTC")
        lines.append(f"\033[1mEMA Live — {now} — every {interval}s — [{channel}]\033[0m")
        lines.append("─" * 64)

        if channel in ("all", "heartbeat"):
            data = fetch_section("/api/health")
            if data:
                lines.append(f"\033[36m[heartbeat]\033[0m {data.get('status', 'ok')}")
            else:
                lines.append(f"\033[36m[heartbeat]\033[0m \033[31moffline\033[0m")

        if channel in ("all", "pipeline", "executions"):
            data = fetch_section("/api/executions")
            execs = (data.get("executions", []) if data else [])[:7]
            lines.append(f"\n\033[36m[pipeline]\033[0m {len(execs)} recent executions")
            for e in execs:
                s = e.get("status", "?")
                icon = {"completed": "\033[32m✓", "running": "\033[33m▶", "failed": "\033[31m✗"}.get(s, "\033[0m·")
                title = (e.get("title") or e.get("objective", "?"))[:42]
                lines.append(f"  {icon} {s:<10}\033[0m {title}  {fmt_time(e.get('inserted_at'))}")

        if channel in ("all", "tasks"):
            data = fetch_section("/api/tasks")
            tasks = data.get("tasks", []) if data else []
            running = [t for t in tasks if t.get("status") == "running"]
            pending = [t for t in tasks if t.get("status") in ("todo", "pending", "created")]
            lines.append(f"\n\033[36m[tasks]\033[0m {len(running)} running, {len(pending)} pending")
            for t in running[:3]:
                lines.append(f"  ▶ {(t.get('title') or '?')[:55]}")
            for t in pending[:2]:
                lines.append(f"  ○ {(t.get('title') or '?')[:55]}")

        if channel in ("all", "proposals"):
            data = fetch_section("/api/proposals")
            props = data.get("proposals", []) if data else []
            queued = [p for p in props if p.get("status") in ("queued", "pending", "generating")]
            lines.append(f"\n\033[36m[proposals]\033[0m {len(queued)} queued, {len(props)} total")
            for p in queued[:3]:
                lines.append(f"  ◆ {(p.get('title') or '?')[:55]}")

        if channel in ("all", "agents"):
            data = fetch_section("/api/agents")
            agents = data.get("agents", []) if data else []
            lines.append(f"\n\033[36m[agents]\033[0m {len(agents)} configured")
            for a in agents[:5]:
                lines.append(f"  • {a.get('slug','?'):<16} {(a.get('model') or 'default'):<18} {a.get('status', 'active')}")

        if channel in ("all", "braindump", "inbox"):
            data = fetch_section("/api/brain-dump/items")
            items = data.get("items", []) if data else []
            unprocessed = [i for i in items if i.get("status") != "processed"]
            lines.append(f"\n\033[36m[brain-dump]\033[0m {len(unprocessed)} unprocessed")
            for i in unprocessed[:3]:
                lines.append(f"  ▸ {(i.get('content') or '?')[:55]}  {fmt_time(i.get('inserted_at'))}")

        if channel in ("all", "focus"):
            data = fetch_section("/api/focus/current")
            if data and data.get("session", {}).get("id"):
                s = data["session"]
                lines.append(f"\n\033[36m[focus]\033[0m Active: {s.get('status','?')}")
            else:
                lines.append(f"\n\033[36m[focus]\033[0m No active session")

        if channel in ("all", "babysitter"):
            data = fetch_section("/api/babysitter/state")
            if data:
                state = data.get("state", data)
                summary = str(state)[:80] if not isinstance(state, dict) else ", ".join(f"{k}={v}" for k, v in list(state.items())[:4])
                lines.append(f"\n\033[36m[babysitter]\033[0m {summary[:60]}")

        if channel in ("all", "tokens", "cost"):
            data = fetch_section("/api/tokens/budget")
            if data:
                used = data.get("used_today") or data.get("tokens_today", "—")
                limit = data.get("daily_limit") or data.get("budget", "—")
                cost = data.get("cost_today") or data.get("cost_usd", "—")
                lines.append(f"\n\033[36m[tokens]\033[0m used: {used} | limit: {limit} | cost: ${cost}")

        lines.append(f"\n\033[2mCtrl+C to exit\033[0m")
        return "\n".join(lines)

    try:
        while True:
            output = render()
            sys.stdout.write("\033[2J\033[H")
            sys.stdout.write(output + "\n")
            sys.stdout.flush()
            time.sleep(interval)
    except KeyboardInterrupt:
        sys.stdout.write("\033[2J\033[H")
        out("Watch stopped.")


