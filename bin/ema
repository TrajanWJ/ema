        out_json(sessions); return
    for s in sessions:
        out(f"  [{s.get('id','')}] {s.get('objective','')} — {s.get('status','')}")

def cmd_orchestrator_show(client, args):
    data = client.get(f"/api/orchestrator/sessions/{args.id}")
    record = data.get("session", data.get("data", data))
    if USE_JSON:
        out_json(record); return
    for k, v in record.items():
        out(f"  {k:<16} {v}")

def cmd_orchestrator_spawn(client, args):
    payload = {"objective": args.objective}
    if getattr(args, "agent", None): payload["agent"] = args.agent
    if getattr(args, "project", None): payload["project"] = args.project
    data = client.post("/api/orchestrator/sessions/spawn", payload)
    r = data.get("session", data.get("data", data))
    if USE_JSON:
        out_json(r)
    else:
        out(f"Spawned session: {r.get('id')}")

def cmd_orchestrator_resume(client, args):
    data = client.post(f"/api/orchestrator/sessions/{args.id}/resume", {})
    if USE_JSON:
        out_json(data)
    else:
        out(f"Resumed session {args.id}")

def cmd_orchestrator_kill(client, args):
    data = client.post(f"/api/orchestrator/sessions/{args.id}/kill", {})
    if USE_JSON:
        out_json(data)
    else:
        out(f"Killed session {args.id}")

def cmd_orchestrator_check(client, args):
    data = client.get(f"/api/orchestrator/sessions/{args.id}/check")
    if USE_JSON:
        out_json(data); return
    for k, v in data.items():
        out(f"  {k:<16} {v}")

def cmd_orchestrator_context(client, args):
    data = client.get("/api/orchestrator/context")
    if USE_JSON:
        out_json(data); return
    for k, v in data.items():
        out(f"  {k:<16} {v}")


# ── ingest ───────────────────────────────────────────────────────────────────

def cmd_ingest_list(client, args):
    data = client.get("/api/ingest-jobs")
    jobs = data.get("ingest_jobs", data.get("data", []))
    if USE_JSON:
        out_json(jobs); return
    rows = [[j.get("id",""), j.get("source",""), j.get("status",""), j.get("items","")] for j in jobs]
    table(rows, ["ID", "Source", "Status", "Items"])

def cmd_ingest_show(client, args):
    data = client.get(f"/api/ingest-jobs/{args.id}")
    record = data.get("ingest_job", data.get("data", data))
    if USE_JSON:
        out_json(record); return
    for k, v in record.items():
        out(f"  {k:<16} {v}")

def cmd_ingest_create(client, args):
    payload = {"source": args.source}
    data = client.post("/api/ingest-jobs", {"ingest_job": payload})
    r = data.get("ingest_job", data.get("data", data))
    if USE_JSON:
        out_json(r)
    else:
        out(f"Created ingest job: {r.get('id')}")

def cmd_ingest_update(client, args):
    payload = {}
    if getattr(args, "source", None): payload["source"] = args.source
    if getattr(args, "status", None): payload["status"] = args.status
    data = client.put(f"/api/ingest-jobs/{args.id}", {"ingest_job": payload})
    r = data.get("ingest_job", data.get("data", data))
    if USE_JSON:
        out_json(r)
    else:
        out(f"Updated ingest job: {r.get('id')}")

def cmd_ingest_delete(client, args):
    client.delete(f"/api/ingest-jobs/{args.id}")
    out(f"Deleted ingest job {args.id}")


# ─── Arg parsing ──────────────────────────────────────────────────────────────

def build_parser():
    shared = argparse.ArgumentParser(add_help=False)
    shared.add_argument("--host", "-H", default=None, help="Daemon URL (default: localhost:4488)")
    shared.add_argument("--json", "-j", action="store_true", help="Output raw JSON")
    shared.add_argument("--quiet", "-q", action="store_true", help="Suppress non-error output")
    shared.add_argument("--verbose", "-v", action="store_true", help="Show request details")

    p = argparse.ArgumentParser(
        prog="ema",
        description="EMA CLI — terminal client for the EMA daemon",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        parents=[shared],
        epilog="""
Commands:
  ema dump "thought"                   Quick brain dump
  ema task create|list|get|dispatch|status
  ema project create|list|view|context|dependencies
  ema proposal list|view|dispatch
  ema exec list|get|create|approve|cancel|diff
  ema agent list|get|chat|conversations
  ema goal list|create|get|update
  ema brain-dump create|list|process|delete
  ema focus start|stop|pause|resume|current|today
  ema habit list|create|toggle|today|archive
  ema journal read|write|search
  ema provider list|status
  ema tokens summary|budget
  ema vault search
  ema watch [--channel heartbeat|pipeline|tasks|...]
  ema dispatch status|logs
  ema health check
  ema status
  ema contact list|show|create|update|delete
  ema finance list|show|create|update|delete|summary
  ema invoice list|show|create|update|delete|send|mark-paid
  ema routine list|show|create|update|delete|toggle|run
  ema meeting list|show|create|update|delete|upcoming
  ema temporal rhythm|now|best-time|log|history
  ema intelligence log-outcome|log-mcp|git-events|suggestions|apply|sync-status|scan
  ema pipeline stats|bottlenecks|throughput
  ema obsidian list|search|read|create
  ema security posture|audit
  ema vm health|containers|check
  ema onboarding status|readiness|run
  ema prompt list|show|create|update|delete|version
  ema decision list|show|create|update|delete
  ema clipboard list|create|delete|pin
  ema orchestrator list|show|spawn|resume|kill|check|context
  ema ingest list|show|create|update|delete

Examples:
  ema dump "investigate auth token expiry"
  ema agent chat main "what should I work on?"
  ema exec list --status running
  ema exec create "research auth patterns" --mode research
  ema watch --interval 5 --channel pipeline
  ema focus start --duration 25 --task <id>
  ema journal write "Shipped the auth refactor" --mood good
  ema habit today
  ema goal create "Ship EMA v2" --description "Full CLI + TUI"
  ema provider list
  ema task create "Fix auth module" --project proslync
  ema status
        """
    )

    p.add_argument("--version", action="version", version="ema 2.0.0")

    sub = p.add_subparsers(dest="group", metavar="COMMAND")

    # ── task ──
    task_p = sub.add_parser("task", help="Task management", parents=[shared])
    task_sub = task_p.add_subparsers(dest="action", metavar="ACTION")

    tc = task_sub.add_parser("create", help="Create a task")
    tc.add_argument("title", help="Task title")
    tc.add_argument("--project", "-p", help="Project id or slug")
    tc.add_argument("--priority", type=int, choices=[1,2,3,4,5], help="Priority 1=critical 5=minimal")
    tc.add_argument("--due", help="Due date (ISO8601)")
    tc.add_argument("--description", help="Task description")
    tc.add_argument("--status", default="todo", help="Initial status (default: todo)")

    tl = task_sub.add_parser("list", help="List tasks")
    tl.add_argument("--project", "-p", help="Filter by project")
    tl.add_argument("--status", "-s", help="Filter by status")
    tl.add_argument("--overdue", action="store_true", help="Only overdue tasks")
    tl.add_argument("--limit", "-n", type=int, help="Max results")

    tg = task_sub.add_parser("get", help="Get task details")
    tg.add_argument("task_id", help="Task ID")

    td = task_sub.add_parser("dispatch", help="Dispatch a task to an agent")
    td.add_argument("task_id", help="Task ID")
    td.add_argument("--agent", "-a", help="Override agent")
    td.add_argument("--scope", help="Scope constraint")
    td.add_argument("--context", "-c", help="Additional context")
    td.add_argument("--dry-run", action="store_true", help="Show what would run without executing")

    ts = task_sub.add_parser("status", help="Get task status")
    ts.add_argument("task_id", help="Task ID")

    # ── project ──
    proj_p = sub.add_parser("project", help="Project management", parents=[shared])
    proj_sub = proj_p.add_subparsers(dest="action", metavar="ACTION")

    pc = proj_sub.add_parser("create", help="Create a project")
    pc.add_argument("name", help="Project name")
    pc.add_argument("--slug", help="URL-safe slug (auto-derived from name)")
    pc.add_argument("--description", help="Description")
    pc.add_argument("--path", help="Local filesystem path")
    pc.add_argument("--repo", help="GitHub repo URL")
