            cmd_orchestrator_check(client, args)
        elif args.action == "context":
            cmd_orchestrator_context(client, args)

    elif args.group == "ingest":
        if not args.action:
            parser.parse_args(["ingest", "--help"])
        elif args.action == "list":
            cmd_ingest_list(client, args)
        elif args.action == "show":
            cmd_ingest_show(client, args)
        elif args.action == "create":
            cmd_ingest_create(client, args)
        elif args.action == "update":
            cmd_ingest_update(client, args)
        elif args.action == "delete":
            cmd_ingest_delete(client, args)

    elif args.group == "watch":
        cmd_watch(client, args)


if __name__ == "__main__":
    main()
