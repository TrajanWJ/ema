"""EMA Executive Dashboard — Terminal UI

Launch: uv run scripts/ema-tui
Or:     ema tui
"""

import json
import os
import sys
import urllib.request
import urllib.error
from datetime import datetime, timezone

# ── HTTP Client (mirrors scripts/ema pattern) ──

BASE_URL = os.environ.get("EMA_HOST", "http://localhost:4488")


def api_get(path, params=None):
    url = BASE_URL + path
    if params:
        qs = "&".join(f"{k}={v}" for k, v in params.items() if v is not None)
        if qs:
            url += "?" + qs
    try:
        req = urllib.request.Request(url, headers={"Accept": "application/json"})
        with urllib.request.urlopen(req, timeout=10) as resp:
            return json.loads(resp.read().decode())
    except Exception:
        return {}


def api_post(path, data):
    url = BASE_URL + path
    try:
        body = json.dumps(data).encode()
        req = urllib.request.Request(url, data=body, headers={
            "Content-Type": "application/json",
            "Accept": "application/json",
        }, method="POST")
        with urllib.request.urlopen(req, timeout=10) as resp:
            return json.loads(resp.read().decode())
    except Exception:
        return {}


def fmt_ago(ts_str):
    if not ts_str:
        return "—"
    try:
        ts = datetime.fromisoformat(ts_str.replace("Z", "+00:00"))
        delta = datetime.now(timezone.utc) - ts
        secs = int(delta.total_seconds())
        if secs < 60:
            return f"{secs}s"
        if secs < 3600:
            return f"{secs // 60}m"
        if secs < 86400:
            return f"{secs // 3600}h"
        return f"{secs // 86400}d"
    except Exception:
        return "—"


# ── Textual App ──

from textual.app import App, ComposeResult
from textual.binding import Binding
from textual.containers import Horizontal, Vertical, VerticalScroll
from textual.reactive import reactive
from textual.screen import ModalScreen
from textual.widget import Widget
from textual.widgets import (
    DataTable,
    Footer,
    Header,
    Input,
    Label,
    Static,
    TabbedContent,
    TabPane,
)


class StatusBar(Static):
    """Top bar showing actor phases."""

    actors = reactive(list)

    def render(self):
        if not self.actors:
            return "Loading..."
        parts = []
        for a in self.actors:
            name = a.get("name", a.get("slug", "?"))
            phase = a.get("phase", "?")
            atype = a.get("type", a.get("actor_type", "?"))
            icon = "👤" if atype == "human" else "🤖"
            parts.append(f"{icon} {name}:{phase}")
        return "  ".join(parts)


class TaskPanel(Widget):
    """Task list panel."""

    DEFAULT_CSS = """
    TaskPanel { height: 1fr; border: solid $primary; }
    TaskPanel DataTable { height: 1fr; }
    """

    def compose(self) -> ComposeResult:
        yield Static("Tasks", classes="panel-title")
        yield DataTable(id="tasks-table")

    def on_mount(self):
        table = self.query_one("#tasks-table", DataTable)
        table.add_columns("Title", "Status", "Priority", "Age")
        table.cursor_type = "row"
        table.zebra_stripes = True

    def refresh_data(self, tasks):
        table = self.query_one("#tasks-table", DataTable)
        table.clear()
        for t in tasks[:20]:
            title = (t.get("title") or "?")[:40]
            status = t.get("status") or "?"
            pri = {1: "🔴 crit", 2: "🟠 high", 3: "🟡 med", 4: "🔵 low", 5: "⚪ min"}.get(
                t.get("priority"), "?"
            )
            age = fmt_ago(t.get("created_at") or t.get("updated_at"))
            table.add_row(title, status, pri, age)


class ExecutionPanel(Widget):
    """Execution list panel."""

    DEFAULT_CSS = """
    ExecutionPanel { height: 1fr; border: solid $secondary; }
    ExecutionPanel DataTable { height: 1fr; }
    """

    def compose(self) -> ComposeResult:
        yield Static("Executions", classes="panel-title")
        yield DataTable(id="exec-table")

    def on_mount(self):
        table = self.query_one("#exec-table", DataTable)
        table.add_columns("Title", "Mode", "Status", "Age")
        table.cursor_type = "row"
        table.zebra_stripes = True

    def refresh_data(self, executions):
        table = self.query_one("#exec-table", DataTable)
        table.clear()
        for e in executions[:15]:
            title = (e.get("title") or "?")[:35]
            mode = e.get("mode", "?")
            status = e.get("status", "?")
            icon = {"running": "▶", "completed": "✓", "failed": "✗", "created": "○"}.get(status, "·")
            age = fmt_ago(e.get("inserted_at") or e.get("updated_at"))
            table.add_row(title, mode, f"{icon} {status}", age)


class BrainDumpPanel(Widget):
    """Brain dump inbox panel."""

    DEFAULT_CSS = """
    BrainDumpPanel { height: 1fr; border: solid $accent; }
    BrainDumpPanel VerticalScroll { height: 1fr; }
    """

    def compose(self) -> ComposeResult:
        yield Static("Brain Dump", classes="panel-title")
        yield VerticalScroll(id="bd-scroll")

    def refresh_data(self, items):
        scroll = self.query_one("#bd-scroll", VerticalScroll)
        scroll.remove_children()
        for item in items[:10]:
            content = (item.get("content") or "")[:80]
            status = "✓" if item.get("processed") else "○"
            age = fmt_ago(item.get("created_at"))
            scroll.mount(Static(f"{status} [{age}] {content}"))


class PhasePanel(Widget):
    """Phase transition log panel."""

    DEFAULT_CSS = """
    PhasePanel { height: 1fr; border: solid $warning; }
    PhasePanel DataTable { height: 1fr; }
    """

    def compose(self) -> ComposeResult:
        yield Static("Phase Log", classes="panel-title")
        yield DataTable(id="phase-table")

    def on_mount(self):
        table = self.query_one("#phase-table", DataTable)
        table.add_columns("Actor", "From", "To", "Week", "When")
        table.cursor_type = "row"
        table.zebra_stripes = True

    def refresh_data(self, actors):
        table = self.query_one("#phase-table", DataTable)
        table.clear()
        for actor in actors:
            actor_id = actor.get("id", "?")
            name = actor.get("name", actor_id)[:12]
            phases = api_get(f"/api/actors/{actor_id}/phases")
            transitions = phases.get("phase_transitions", phases.get("data", []))
            for t in transitions[:5]:
                frm = t.get("from_phase") or "—"
                to = t.get("to_phase") or "?"
                week = str(t.get("week_number") or "—")
                when = fmt_ago(t.get("transitioned_at"))
                table.add_row(name, frm, to, week, when)


class ProjectPanel(Widget):
    """Projects overview panel."""

    DEFAULT_CSS = """
    ProjectPanel { height: 1fr; border: solid $success; }
    ProjectPanel VerticalScroll { height: 1fr; }
    """

    def compose(self) -> ComposeResult:
        yield Static("Projects", classes="panel-title")
        yield VerticalScroll(id="proj-scroll")

    def refresh_data(self, projects):
        scroll = self.query_one("#proj-scroll", VerticalScroll)
        scroll.remove_children()
        for p in projects[:10]:
            name = p.get("name") or p.get("slug", "?")
            status = p.get("status", "?")
            scroll.mount(Static(f"  {name:<20} {status}"))


class TagPanel(Widget):
    """Tags for the currently selected entity."""

    DEFAULT_CSS = """
    TagPanel { height: 1fr; border: solid $primary; }
    TagPanel VerticalScroll { height: 1fr; }
    """

    def compose(self) -> ComposeResult:
        yield Static("Tags", classes="panel-title")
        yield VerticalScroll()

    def load_tags(self, entity_type, entity_id):
        scroll = self.query_one(VerticalScroll)
        scroll.remove_children()
        if not entity_type or not entity_id:
            scroll.mount(Static("  Select an entity to view tags"))
            return
        data = api_get("/api/tags", {"entity_type": entity_type, "entity_id": str(entity_id)})
        tags = data.get("tags", data.get("data", [])) if isinstance(data, dict) else []
        if not tags:
            scroll.mount(Static("  No tags"))
            return
        for tag in tags:
            name = tag.get("name") or tag.get("tag", "?")
            actor = tag.get("actor_slug", tag.get("actor_id", ""))
            scroll.mount(Static(f"  🏷  {name}  ({actor})"))


class EntityDataPanel(Widget):
    """Per-actor metadata for selected entity."""

    DEFAULT_CSS = """
    EntityDataPanel { height: 1fr; border: solid $secondary; }
    EntityDataPanel VerticalScroll { height: 1fr; }
    """

    def compose(self) -> ComposeResult:
        yield Static("Entity Data", classes="panel-title")
        yield VerticalScroll()

    def load_data(self, entity_type, entity_id, actor_id="human"):
        scroll = self.query_one(VerticalScroll)
        scroll.remove_children()
        if not entity_type or not entity_id:
            scroll.mount(Static("  Select an entity to view data"))
            return
        data = api_get("/api/entity-data", {
            "entity_type": entity_type,
            "entity_id": str(entity_id),
            "actor_id": actor_id,
        })
        items = data.get("entity_data", data.get("data", [])) if isinstance(data, dict) else []
        if not items:
            scroll.mount(Static("  No entity data"))
            return
        for item in items:
            key = item.get("key", "?")
            val = item.get("value", "?")
            scroll.mount(Static(f"  {key}: {val}"))


class ActorPanel(Widget):
    """Actor list with phase status."""

    DEFAULT_CSS = """
    ActorPanel { height: 1fr; border: solid $warning; }
    ActorPanel DataTable { height: 1fr; }
    """

    _actors: list = []

    def compose(self) -> ComposeResult:
        yield Static("Actors  (a=advance phase)", classes="panel-title")
        yield DataTable(id="actor-table")

    def on_mount(self):
        table = self.query_one("#actor-table", DataTable)
        table.add_columns("Name", "Type", "Phase", "Capabilities")
        table.cursor_type = "row"
        table.zebra_stripes = True

    def refresh_data(self, actors):
        self._actors = actors
        table = self.query_one("#actor-table", DataTable)
        table.clear()
        for a in actors[:30]:
            name = a.get("name", a.get("slug", "?"))[:20]
            atype = a.get("type", a.get("actor_type", "?"))
            icon = "👤" if atype == "human" else "🤖"
            phase = a.get("phase", "?")
            caps = ", ".join((a.get("capabilities") or [])[:3])[:30]
            table.add_row(f"{icon} {name}", atype, phase, caps)

    def get_selected_actor(self):
        table = self.query_one("#actor-table", DataTable)
        if table.cursor_row is not None and 0 <= table.cursor_row < len(self._actors):
            return self._actors[table.cursor_row]
        return None


class DetailScreen(ModalScreen):
    """Full detail view for a task or execution."""

    BINDINGS = [
        Binding("escape", "dismiss", "Close"),
        Binding("q", "dismiss", "Close"),
    ]

    DEFAULT_CSS = """
    DetailScreen {
        align: center middle;
    }
    #detail-container {
        width: 80;
        max-height: 40;
        border: thick $primary;
        background: $surface;
        padding: 1 2;
    }
    """

    def __init__(self, entity_type: str, entity: dict):
        super().__init__()
        self.entity_type = entity_type
        self.entity = entity

    def compose(self) -> ComposeResult:
        e = self.entity
        lines = []
        if self.entity_type == "task":
            lines.append(f"[b]Task Detail[/b]")
            lines.append(f"")
            lines.append(f"Title:       {e.get('title', '?')}")
            lines.append(f"Status:      {e.get('status', '?')}")
            pri = {1: "critical", 2: "high", 3: "medium", 4: "low", 5: "minimal"}.get(
                e.get("priority"), "?"
            )
            lines.append(f"Priority:    {pri}")
            lines.append(f"Actor:       {e.get('actor_id', '—')}")
            lines.append(f"Project:     {e.get('project_id', '—')}")
            lines.append(f"Created:     {e.get('created_at', '—')}")
            lines.append(f"Updated:     {e.get('updated_at', '—')}")
            desc = e.get("description") or "—"
            lines.append(f"")
            lines.append(f"Description:")
            for chunk in [desc[i:i+70] for i in range(0, len(desc), 70)]:
                lines.append(f"  {chunk}")
            # Fetch tags
            tid = e.get("id")
            if tid:
                tag_data = api_get("/api/tags", {"entity_type": "task", "entity_id": str(tid)})
                tags = tag_data.get("tags", tag_data.get("data", [])) if isinstance(tag_data, dict) else []
                if tags:
                    tag_names = [t.get("name", "?") for t in tags]
                    lines.append(f"")
                    lines.append(f"Tags:        {', '.join(tag_names)}")
        elif self.entity_type == "execution":
            lines.append(f"[b]Execution Detail[/b]")
            lines.append(f"")
            lines.append(f"Title:       {e.get('title', '?')}")
            lines.append(f"Status:      {e.get('status', '?')}")
            lines.append(f"Mode:        {e.get('mode', '?')}")
            lines.append(f"Actor:       {e.get('actor_id', '—')}")
            lines.append(f"Created:     {e.get('inserted_at', e.get('created_at', '—'))}")
            lines.append(f"Updated:     {e.get('updated_at', '—')}")
            desc = e.get("description") or e.get("output") or "—"
            lines.append(f"")
            lines.append(f"Description:")
            for chunk in [desc[i:i+70] for i in range(0, len(desc), 70)]:
                lines.append(f"  {chunk}")

        lines.append(f"")
        lines.append(f"[dim]Press Escape or q to close[/dim]")

        with Vertical(id="detail-container"):
            yield Static("\n".join(lines))


class BrainDumpScreen(ModalScreen):
    """Modal input for brain dumps."""

    BINDINGS = [
        Binding("escape", "dismiss", "Cancel"),
    ]

    DEFAULT_CSS = """
    BrainDumpScreen {
        align: center middle;
    }
    #dump-container {
        width: 70;
        height: auto;
        max-height: 12;
        border: thick $accent;
        background: $surface;
        padding: 1 2;
    }
    #dump-input {
        margin-top: 1;
    }
    """

    def compose(self) -> ComposeResult:
        with Vertical(id="dump-container"):
            yield Static("[b]Brain Dump[/b]  (Enter to submit, Escape to cancel)")
            yield Input(placeholder="What's on your mind?", id="dump-input")

    def on_mount(self):
        self.query_one("#dump-input", Input).focus()

    def on_input_submitted(self, event: Input.Submitted):
        text = event.value.strip()
        if text:
            result = api_post("/api/brain-dump/items", {"content": text, "source": "tui"})
            if result:
                self.app.notify("Brain dump captured")
            else:
                self.app.notify("Failed to submit brain dump", severity="error")
        self.dismiss()


class EmaDashboard(App):
    """EMA Executive Dashboard"""

    CSS = """
    Screen {
        background: $surface;
    }
    .panel-title {
        text-style: bold;
        padding: 0 1;
        color: $text;
        height: 1;
    }
    #status-bar {
        dock: top;
        height: 1;
        background: $primary-background;
        color: $text;
        padding: 0 2;
        text-style: bold;
    }
    .half-col {
        width: 1fr;
    }
    TabbedContent {
        height: 1fr;
    }
    TabPane {
        height: 1fr;
        padding: 0;
    }
    """

    TITLE = "EMA Executive Dashboard"
    BINDINGS = [
        Binding("q", "quit", "Quit"),
        Binding("r", "refresh", "Refresh"),
        Binding("d", "dump", "Brain Dump"),
        Binding("t", "focus_tasks", "Tasks"),
        Binding("e", "focus_exec", "Executions"),
        Binding("1", "show_tab('dashboard')", "Dashboard"),
        Binding("2", "show_tab('executive')", "Executive"),
        Binding("3", "show_tab('project-tab')", "Projects"),
        Binding("a", "advance_phase", "Advance Phase"),
        Binding("enter", "detail_view", "Detail", show=False),
    ]

    # Store fetched data for detail views
    _tasks: list = []
    _execs: list = []
    _actors: list = []

    def compose(self) -> ComposeResult:
        yield Header()
        yield StatusBar(id="status-bar")
        with TabbedContent(initial="dashboard"):
            with TabPane("Dashboard", id="dashboard"):
                yield Horizontal(
                    Vertical(
                        TaskPanel(id="tasks"),
                        PhasePanel(id="phases"),
                        classes="half-col",
                    ),
                    Vertical(
                        ExecutionPanel(id="executions"),
                        BrainDumpPanel(id="braindump"),
                        classes="half-col",
                    ),
                )
            with TabPane("Executive", id="executive"):
                yield Horizontal(
                    Vertical(
                        ActorPanel(id="actors"),
                        classes="half-col",
                    ),
                    Vertical(
                        EntityDataPanel(id="entity-data"),
                        TagPanel(id="tags"),
                        classes="half-col",
                    ),
                )
            with TabPane("Projects", id="project-tab"):
                yield Horizontal(
                    Vertical(
                        ProjectPanel(id="projects"),
                        classes="half-col",
                    ),
                    Vertical(
                        TagPanel(id="project-tags"),
                        classes="half-col",
                    ),
                )
        yield Footer()

    def on_mount(self):
        self.refresh_all()
        self.set_interval(10, self.refresh_all)

    def refresh_all(self):
        # Fetch all data
        actors_data = api_get("/api/actors")
        actors = actors_data.get("actors", []) if isinstance(actors_data, dict) else []
        self._actors = actors

        tasks_data = api_get("/api/tasks")
        tasks = tasks_data.get("tasks", []) if isinstance(tasks_data, dict) else []
        self._tasks = tasks

        exec_data = api_get("/api/executions")
        execs = exec_data.get("executions", exec_data.get("data", [])) if isinstance(exec_data, dict) else []
        self._execs = execs

        bd_data = api_get("/api/brain-dump/items")
        bd_items = bd_data.get("items", []) if isinstance(bd_data, dict) else []

        proj_data = api_get("/api/projects")
        projects = proj_data.get("projects", proj_data.get("data", [])) if isinstance(proj_data, dict) else []

        # Update panels
        self.query_one("#status-bar", StatusBar).actors = actors
        self.query_one("#tasks", TaskPanel).refresh_data(tasks)
        self.query_one("#executions", ExecutionPanel).refresh_data(execs)
        self.query_one("#braindump", BrainDumpPanel).refresh_data(bd_items)
        self.query_one("#phases", PhasePanel).refresh_data(actors)
        self.query_one("#projects", ProjectPanel).refresh_data(projects)
        self.query_one("#actors", ActorPanel).refresh_data(actors)

    def action_refresh(self):
        self.refresh_all()
        self.notify("Refreshed")

    def action_dump(self):
        self.push_screen(BrainDumpScreen())

    def action_focus_tasks(self):
        self.query_one("#tasks-table", DataTable).focus()

    def action_focus_exec(self):
        self.query_one("#exec-table", DataTable).focus()

    def action_show_tab(self, tab: str) -> None:
        self.query_one(TabbedContent).active = tab

    def action_advance_phase(self):
        """Advance selected actor's phase."""
        try:
            actor_panel = self.query_one("#actors", ActorPanel)
        except Exception:
            self.notify("Switch to Executive tab first", severity="warning")
            return
        actor = actor_panel.get_selected_actor()
        if not actor:
            self.notify("No actor selected", severity="warning")
            return
        actor_id = actor.get("id")
        current = actor.get("phase", "plan")
        cycle = ["plan", "execute", "review", "retro"]
        idx = cycle.index(current) if current in cycle else 0
        next_phase = cycle[(idx + 1) % len(cycle)]
        result = api_post(f"/api/actors/{actor_id}/phase", {"phase": next_phase})
        if result:
            self.notify(f"Phase: {current} → {next_phase}")
            self.refresh_all()
        else:
            self.notify("Failed to advance phase", severity="error")

    def action_detail_view(self):
        """Show detail view for the focused table's selected row."""
        focused = self.focused
        if focused is None:
            return
        widget_id = focused.id
        if widget_id == "tasks-table":
            table = self.query_one("#tasks-table", DataTable)
            row = table.cursor_row
            if row is not None and 0 <= row < len(self._tasks):
                self.push_screen(DetailScreen("task", self._tasks[row]))
        elif widget_id == "exec-table":
            table = self.query_one("#exec-table", DataTable)
            row = table.cursor_row
            if row is not None and 0 <= row < len(self._execs):
                self.push_screen(DetailScreen("execution", self._execs[row]))

    def on_data_table_row_selected(self, event: DataTable.RowSelected):
        """When a row is selected, update tag/entity-data panels."""
        table_id = event.data_table.id
        if table_id == "tasks-table":
            row = event.cursor_row
            if 0 <= row < len(self._tasks):
                task = self._tasks[row]
                tid = task.get("id")
                try:
                    self.query_one("#tags", TagPanel).load_tags("task", tid)
                    self.query_one("#entity-data", EntityDataPanel).load_data("task", tid)
                except Exception:
                    pass
        elif table_id == "exec-table":
            row = event.cursor_row
            if 0 <= row < len(self._execs):
                exc = self._execs[row]
                eid = exc.get("id")
                try:
                    self.query_one("#tags", TagPanel).load_tags("execution", eid)
                    self.query_one("#entity-data", EntityDataPanel).load_data("execution", eid)
                except Exception:
                    pass


if __name__ == "__main__":
    EmaDashboard().run()
