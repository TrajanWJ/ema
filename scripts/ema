# ── data (per-entity actor data) ────────────────────────────────────────────

def cmd_data_get(client, args):
    entity_type, entity_id = _split_entity_ref(args.entity_ref)
    params = {
        "entity_type": entity_type,
        "entity_id": entity_id,
        "actor_id": args.actor,
    }
    result = client.get("/api/entity-data", params=params)
    items = result.get("data", []) if isinstance(result, dict) else result

    # Filter by key
    items = [d for d in items if d.get("key") == args.key]

    if USE_JSON:
        out_json(items)
        return

    if not items:
        out(f"No data for key '{args.key}' on {args.entity_ref}")
        return
    for d in items:
        out(f"{d.get('key')}: {d.get('value')}")


def cmd_data_set(client, args):
    entity_type, entity_id = _split_entity_ref(args.entity_ref)
    payload = {
        "entity_type": entity_type,
        "entity_id": entity_id,
        "actor_id": args.actor,
        "key": args.key,
        "value": args.value,
    }
    result = client.post("/api/entity-data", payload)

    if USE_JSON:
        out_json(result)
        return

    out(f"Set {args.entity_ref} [{args.key}] = {args.value}")


def cmd_data_list(client, args):
    entity_type, entity_id = _split_entity_ref(args.entity_ref)
    params = {
        "entity_type": entity_type,
        "entity_id": entity_id,
        "actor_id": args.actor,
    }
    result = client.get("/api/entity-data", params=params)
    items = result.get("data", []) if isinstance(result, dict) else result

