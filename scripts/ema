    if USE_JSON:
        out_json(result)
        return
    session = result.get("session", result)
    if not session or not session.get("id"):
        out("No active focus session.")
        return
    out(f"Active: {session.get('id', '?')}")
    out(f"  Status: {session.get('status', '?')}")
    if session.get("task_id"):
        out(f"  Task:   {session['task_id']}")


def cmd_focus_today(client, args):
    result = client.get("/api/focus/today")
    if USE_JSON:
        out_json(result)
        return
    out("Today's focus:")
    out(f"  Sessions:   {result.get('session_count', 0)}")
    total = result.get("total_ms") or result.get("total_minutes", 0)
    if isinstance(total, (int, float)) and total > 60000:
        out(f"  Total time: {int(total) // 60000}m")
    else:
        out(f"  Total time: {total}")


