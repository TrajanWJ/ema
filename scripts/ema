# ── journal ──────────────────────────────────────────────────────────────────

def cmd_journal_read(client, args):
    date = args.date or datetime.now().strftime("%Y-%m-%d")
    result = client.get(f"/api/journal/{date}")
    if USE_JSON:
        out_json(result)
        return
    entry = result.get("entry", result)
    if not entry or not entry.get("content"):
        out(f"No journal entry for {date}.")
        return
    out(f"Journal — {date}")
    if entry.get("mood"):
        out(f"  Mood:   {entry['mood']}")
    if entry.get("one_thing"):
        out(f"  Focus:  {entry['one_thing']}")
    if entry.get("energy_p") or entry.get("energy_m") or entry.get("energy_e"):
        out(f"  Energy: AM={entry.get('energy_p','—')} PM={entry.get('energy_m','—')} EVE={entry.get('energy_e','—')}")
    out(f"\n{entry.get('content', '')}")


def cmd_journal_write(client, args):
    date = args.date or datetime.now().strftime("%Y-%m-%d")
    content = " ".join(args.content) if isinstance(args.content, list) else args.content
    payload = {"content": content}
    if args.mood:
        payload["mood"] = args.mood
    if args.one_thing:
        payload["one_thing"] = args.one_thing
    result = client.put(f"/api/journal/{date}", payload)
    if USE_JSON:
        out_json(result)
        return
    out(f"Journal updated for {date}.")


def cmd_journal_search(client, args):
    result = client.get("/api/journal/search", params={"q": args.query})
    if USE_JSON:
        out_json(result)
        return
    entries = result.get("entries", []) if isinstance(result, dict) else result
    if not entries:
        out("No matching journal entries.")
        return
    for e in entries:
        date = e.get("date") or fmt_time(e.get("inserted_at"))
        content = (e.get("content") or "")[:80]
        out(f"  {date} | {content}")


# ── provider ─────────────────────────────────────────────────────────────────

def cmd_provider_list(client, args):
    result = client.get("/api/orchestration/stats")
    if USE_JSON:
        out_json(result)
        return
    stats = result
    out(f"Routing strategy: {stats.get('default_strategy', '—')}")
    out(f"Total routed:     {stats.get('total_routes', 0)}")
    providers = stats.get("providers", [])
    if providers:
        out(f"\nProviders:")
        rows = []
        for p in providers:
            rows.append([
                p.get("id", "?")[:20],
                p.get("type", "?")[:14],
                p.get("status", "?")[:10],
                str(p.get("models", []))[:30] if p.get("models") else "—",
            ])
        table(rows, ["ID", "TYPE", "STATUS", "MODELS"], [22, 16, 11, 32])
    fitness = stats.get("fitness", stats.get("agents", []))
    if fitness:
        out(f"\nAgent fitness:")
        for f in fitness:
            name = f.get("agent") or f.get("name") or f.get("id", "?")
            score = f.get("composite") or f.get("score") or "—"
            out(f"  {name}: {score}")


def cmd_provider_status(client, args):
    result = client.get("/api/orchestration/fitness")
    if USE_JSON:
        out_json(result)
        return
    out("Provider fitness:")
    fitness = result.get("fitness", result.get("agents", []))
    if isinstance(fitness, list):
        for f in fitness:
            name = f.get("agent") or f.get("name") or f.get("id", "?")
            out(f"\n  {name}:")
            for k in ("composite", "success_rate", "latency_ms", "run_count"):
                if k in f:
                    out(f"    {k}: {f[k]}")
    else:
        out(f"  {fitness}")


