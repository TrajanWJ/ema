def cmd_em_velocity(client, args):
    result = client.get(f"/api/actors/{args.actor}/phases")

    if USE_JSON:
        out_json(result)
        return

    phases = result.get("phases", []) if isinstance(result, dict) else result
    completed = [p for p in phases if p.get("status") == "completed"]
    total = len(phases)
    done = len(completed)

    out(f"Actor: {args.actor}")
    out(f"  Total phases:     {total}")
    out(f"  Completed:        {done}")
    out(f"  Weeks completed:  {done}")
    if total > 0:
        out(f"  Completion:       {done * 100 // total}%")


