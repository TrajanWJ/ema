# ── focus ────────────────────────────────────────────────────────────────────

def _split_entity_ref(ref):
    """Split 'type:id' entity reference. Dies if format is invalid."""
    if ":" not in ref:
        die(f"Invalid entity_ref '{ref}'. Expected format: type:id (e.g. task:task_42)")
    entity_type, entity_id = ref.split(":", 1)
    if not entity_type or not entity_id:
        die(f"Invalid entity_ref '{ref}'. Both type and id are required.")
    return entity_type, entity_id


