#!/usr/bin/env python3
"""
EMA CLI — Terminal client for the EMA daemon at localhost:4488
Version: 2.0.0
"""

import sys
import os
import json
import argparse
import urllib.request
import urllib.error
import urllib.parse
import socket
import re
import subprocess
from datetime import datetime
from pathlib import Path

# ─── Config ──────────────────────────────────────────────────────────────────

CONFIG_PATH = Path.home() / ".ema" / "config.json"
DEFAULT_HOST = "localhost:4488"

def load_config():
    if CONFIG_PATH.exists():
        try:
            return json.loads(CONFIG_PATH.read_text())
        except Exception:
            pass
    return {}

def save_config(cfg):
    CONFIG_PATH.parent.mkdir(parents=True, exist_ok=True)
    CONFIG_PATH.write_text(json.dumps(cfg, indent=2))

CONFIG = load_config()

# ─── HTTP client ─────────────────────────────────────────────────────────────

class EMAClient:
    def __init__(self, host, verbose=False):
        self.base = f"http://{host}"
        self.verbose = verbose

    def request(self, method, path, data=None, params=None):
        url = self.base + path
        if params:
            url += "?" + urllib.parse.urlencode({k: v for k, v in params.items() if v is not None})

        body = json.dumps(data).encode() if data is not None else None
        headers = {"Content-Type": "application/json", "Accept": "application/json"}

        if self.verbose:
            print(f"  → {method} {url}", file=sys.stderr)
            if data:
                print(f"  → body: {json.dumps(data)}", file=sys.stderr)

        try:
            req = urllib.request.Request(url, data=body, headers=headers, method=method)
            with urllib.request.urlopen(req, timeout=15) as resp:
                raw = resp.read().decode()
                if self.verbose:
                    print(f"  ← {resp.status} {raw[:200]}", file=sys.stderr)
                if raw:
                    return json.loads(raw)
                return {}
        except urllib.error.HTTPError as e:
            raw_body = e.read().decode()
            try:
                err_data = json.loads(raw_body)
                errors = err_data.get("errors", err_data)
                die(f"API error {e.code}: {json.dumps(errors)}", exit_code=1)
            except (json.JSONDecodeError, ValueError):
                if "PendingMigrationError" in raw_body:
                    die(
                        f"EMA daemon has pending migrations (HTTP {e.code}).\n"
                        f"  → Fix: cd ~/Projects/ema/daemon && mix ecto.migrate && mix phx.server",
                        exit_code=2
                    )
                if "CompileError" in raw_body:
                    match = re.search(r'CompileError\)([^<]+)', raw_body)
                    detail = match.group(1).strip() if match else "code compilation error"
                    die(
                        f"EMA daemon compile error (HTTP {e.code}): {detail}\n"
                        f"  → Fix: cd ~/Projects/ema/daemon && mix compile && mix phx.server",
                        exit_code=2
                    )
                if "<html" in raw_body.lower():
                    die(f"API error {e.code}: endpoint not found or server error\n  Path: {path}", exit_code=1)
                die(f"API error {e.code}: {raw_body[:200]}", exit_code=1)
        except urllib.error.URLError as e:
            die(
                f"Cannot reach EMA daemon at {self.base.replace('http://', '')}\n"
                f"  → Try: cd ~/Projects/ema/daemon && mix phx.server\n"
                f"  → Or:  ema status",
                exit_code=2
            )
        except Exception as e:
            die(f"Request failed: {e}", exit_code=1)

    def get(self, path, params=None):
        return self.request("GET", path, params=params)

    def post(self, path, data=None):
        return self.request("POST", path, data=data or {})

    def put(self, path, data=None):
        return self.request("PUT", path, data=data or {})

    def patch(self, path, data=None):
        return self.request("PATCH", path, data=data or {})

    def delete(self, path):
        return self.request("DELETE", path)

# ─── Output helpers ───────────────────────────────────────────────────────────

USE_JSON = False
QUIET = False

def out_json(data):
    print(json.dumps(data, indent=2, default=str))

def out(msg):
    if not QUIET:
        print(msg)

def err(msg):
    print(f"Error: {msg}", file=sys.stderr)

def die(msg, exit_code=1):
    print(f"Error: {msg}", file=sys.stderr)
    sys.exit(exit_code)

def fmt_time(iso):
    if not iso:
        return "—"
    try:
        from datetime import timezone
        dt = datetime.fromisoformat(iso.replace("Z", "+00:00"))
        now = datetime.now(timezone.utc)
        delta = now - dt
        secs = int(delta.total_seconds())
        if secs < 60:
            return f"{secs}s ago"
        elif secs < 3600:
            return f"{secs//60}m ago"
        elif secs < 86400:
            return f"{secs//3600}h ago"
        else:
            return f"{secs//86400}d ago"
    except Exception:
        return iso[:10]

def fmt_priority(p):
    if p is None:
        return "—"
    mapping = {1: "critical", 2: "high", 3: "medium", 4: "low", 5: "minimal"}
    return mapping.get(int(p), str(p))

def slugify(name):
    """Convert name to URL-safe slug."""
    slug = name.lower()
    slug = re.sub(r'[^a-z0-9]+', '-', slug)
    slug = slug.strip('-')
    return slug

def table(rows, headers, widths=None):
    """Print a table. rows = list of lists."""
    if not rows:
        out("(no results)")
        return
    if widths is None:
        widths = []
        for i, h in enumerate(headers):
            col_max = max([len(str(r[i])) for r in rows] + [len(h)])
            widths.append(col_max)
    fmt = "  ".join(f"{{:<{w}}}" for w in widths)
    out(fmt.format(*headers))
    out("  ".join("─" * w for w in widths))
    for r in rows:
        out(fmt.format(*[str(v)[:w] for v, w in zip(r, widths)]))


# ─── MCP helpers ──────────────────────────────────────────────────────────────


def parse_cli_value(raw):
    if raw == "":
        return ""

    lowered = raw.lower()
    if lowered == "true":
        return True
    if lowered == "false":
        return False
    if lowered == "null":
        return None

    try:
        if raw.startswith(("{", "[", '"')) or raw in ("0",) or raw[0].isdigit() or raw[0] == "-":
            return json.loads(raw)
    except Exception:
        pass

    return raw


def parse_mcp_args(arg_pairs, args_json=None):
    payload = {}

    for pair in arg_pairs or []:
        if "=" not in pair:
            die(f"Invalid --arg '{pair}'. Expected KEY=VALUE.")
        key, value = pair.split("=", 1)
        key = key.strip()
        if not key:
            die(f"Invalid --arg '{pair}'. Key cannot be empty.")
        payload[key] = parse_cli_value(value)

    if args_json:
        try:
            parsed = json.loads(args_json)
        except json.JSONDecodeError as e:
            die(f"Invalid --args-json payload: {e}")
        if not isinstance(parsed, dict):
            die("--args-json must decode to a JSON object")
        payload.update(parsed)

    return payload


def resolve_project_ref(client, ref):
    result = client.get("/api/projects")
    projects = result.get("projects", result if isinstance(result, list) else [])

    for proj in projects:
        if ref in [str(proj.get("id")), proj.get("slug"), proj.get("name")]:
            return str(proj.get("id"))

    die(f"Project not found: {ref}")


def read_mcp_resource(client, uri):
    parsed = urllib.parse.urlparse(uri)
    base_uri = f"{parsed.scheme}://{parsed.netloc}{parsed.path}"
    query = urllib.parse.parse_qs(parsed.query)

    if base_uri == "ema://context/operator":
        data = client.get("/api/context/operator/package")
    elif base_uri == "ema://context/project":
        ref = (query.get("id") or [None])[0]
        if not ref:
            die("Resource ema://context/project requires ?id=<project_id_or_slug>")
        project_id = resolve_project_ref(client, ref)
        data = client.get(f"/api/context/project/{project_id}/package")
    elif base_uri == "ema://projects/active":
        data = client.get("/api/projects", params={"status": "active", "include_context": "true"})
    elif base_uri == "ema://tasks/pending":
        data = client.get("/api/tasks", params={"status": "pending,blocked", "include_context": "true"})
    elif base_uri == "ema://proposals/recent":
        data = client.get("/api/proposals", params={"status": "approved", "limit": 5, "order": "desc"})
    elif base_uri == "ema://bootstrap/status":
        data = client.get("/api/onboarding/status")
    elif base_uri == "ema://focus/current":
        data = client.get("/api/focus/current")
    elif base_uri == "ema://vault/search":
        search = (query.get("q") or [None])[0]
        if not search:
            die("Resource ema://vault/search requires ?q=<query>")
        data = client.get("/api/vectors/query", params={"q": search, "k": 5})
    elif base_uri == "ema://intents/active":
        params = {"status": "active", "limit": 20}
        project_id = (query.get("project_id") or [None])[0]
        if project_id:
            params["project_id"] = project_id
        data = client.get("/api/intents", params=params)
    elif base_uri == "ema://intents/tree":
        project_id = (query.get("project_id") or [None])[0]
        params = {"project_id": project_id} if project_id else None
        data = client.get("/api/intents/tree", params=params)
    else:
        die(f"Unknown MCP resource URI: {uri}")

    return {
        "uri": uri,
        "mimeType": "application/json",
        "data": data
    }


def cmd_mcp_tools(client, args):
    result = client.get("/api/mcp/tools")
    tools = result.get("tools", [])

    if args.name:
        tools = [t for t in tools if t.get("name") == args.name]

    if USE_JSON:
        out_json(tools)
        return

    rows = []
    for tool in tools:
        schema = tool.get("inputSchema", {})
        required = ",".join(schema.get("required", [])) or "—"
        props = ",".join(schema.get("properties", {}).keys()) or "—"
        scope = "session" if str(tool.get("name", "")).startswith("ema_") else "core"
        rows.append([tool.get("name", "—"), scope, required, props, tool.get("description", "")[:56]])

    table(rows, ["name", "scope", "required", "args", "description"], widths=[24, 8, 20, 28, 56])


def cmd_mcp_resources(client, args):
    result = client.get("/api/mcp/tools")
    resources = result.get("resources", [])

    if args.uri:
        resources = [r for r in resources if r.get("uri") == args.uri]

    if USE_JSON:
        out_json(resources)
        return

    rows = [[r.get("uri", "—"), r.get("name", "—"), r.get("mimeType", "—"), r.get("description", "")[:64]] for r in resources]
    table(rows, ["uri", "name", "mime", "description"], widths=[28, 22, 18, 64])


def cmd_mcp_read(client, args):
    result = read_mcp_resource(client, args.uri)

    if USE_JSON:
        out_json(result)
        return

    out(f"URI: {result['uri']}")
    out(f"MIME: {result['mimeType']}")
    out(json.dumps(result["data"], indent=2, default=str))


def cmd_mcp_call(client, args):
    arguments = parse_mcp_args(args.arg, args.args_json)
    payload = {"name": args.name, "arguments": arguments}
    result = client.post("/api/mcp/tools/execute", payload)

    if USE_JSON:
        out_json(result)
        return

    out(f"Tool: {result.get('name', args.name)}")
    out(f"Request ID: {result.get('request_id', '—')}")
    out(json.dumps(result.get("result", result), indent=2, default=str))


def cmd_mcp_doctor(client, args):
    daemon_ok = False
    mcp_ok = False
    launcher = Path(__file__).resolve().parent.parent / "daemon" / "bin" / "ema-mcp"

    try:
        health = client.get("/api/health")
        daemon_ok = True
    except SystemExit:
        health = None

    try:
        registry = client.get("/api/mcp/tools")
        mcp_ok = True
    except SystemExit:
        registry = None

    launcher_exists = launcher.exists()
    launcher_help = None
    launcher_version = None

    if launcher_exists:
        try:
            launcher_help = subprocess.run(
                [str(launcher), "--help"],
                capture_output=True,
                text=True,
                timeout=10,
                check=False
            ).stdout.strip()
            launcher_version = subprocess.run(
                [str(launcher), "--version"],
                capture_output=True,
                text=True,
                timeout=10,
                check=False
            ).stdout.strip()
        except Exception as e:
            launcher_help = f"(failed: {e})"

    config = {
        "mcpServers": {
            "ema": {
                "command": str(launcher),
                "cwd": str(launcher.parent.parent)
            }
        }
    }

    report = {
        "daemon": {
            "ok": daemon_ok,
            "health": health
        },
        "mcp_registry": {
            "ok": mcp_ok,
            "tool_count": len((registry or {}).get("tools", [])),
            "resource_count": len((registry or {}).get("resources", []))
        },
        "launcher": {
            "path": str(launcher),
            "exists": launcher_exists,
            "version": launcher_version,
            "help_available": bool(launcher_help)
        },
        "claude_config": config
    }

    if USE_JSON:
        out_json(report)
        return

    out(f"daemon     {'ok' if daemon_ok else 'down'}")
    out(f"registry   {'ok' if mcp_ok else 'down'}")
    out(f"launcher   {'ok' if launcher_exists else 'missing'}  {launcher}")
    if launcher_version:
        out(f"version    {launcher_version}")
    if mcp_ok:
        out(f"surface    {report['mcp_registry']['tool_count']} tools, {report['mcp_registry']['resource_count']} resources")
    out("")
    out("Claude MCP config:")
    out(json.dumps(config, indent=2))


def cmd_mcp_config(client, args):
    launcher = Path(__file__).resolve().parent.parent / "daemon" / "bin" / "ema-mcp"
    config = {
        "mcpServers": {
            "ema": {
                "command": str(launcher),
                "cwd": str(launcher.parent.parent)
            }
        }
    }

    if USE_JSON or args.format == "json":
        out_json(config)
        return

    out(json.dumps(config, indent=2))


def cmd_mcp_stdio(client, args):
    launcher = Path(__file__).resolve().parent.parent / "daemon" / "bin" / "ema-mcp"

    if not launcher.exists():
        die(f"MCP launcher not found: {launcher}")

    os.execv(str(launcher), [str(launcher)])

# ─── Command implementations ──────────────────────────────────────────────────

# ── task ──────────────────────────────────────────────────────────────────────

def cmd_task_create(client, args):
    # API expects flat params (not nested under "task")
    payload = {"title": args.title, "status": args.status or "todo"}
    if args.project:
        payload["project_id"] = args.project
    if args.priority:
        payload["priority"] = args.priority
    if args.due:
        payload["due_date"] = args.due
    if args.description:
        payload["description"] = args.description

    result = client.post("/api/tasks", payload)
    task = result

    if USE_JSON:
        out_json(task)
        return

    tid = task.get("id", "?")
    title = task.get("title", "?")
    status = task.get("status", "todo")
    proj = task.get("project_id") or "—"

    # Structural keyword detection
    structural = ["refactor", "restructure", "rewrite", "migrate", "redesign", "rearchitect"]
    warnings = [kw for kw in structural if kw in title.lower()]
    if warnings:
        out(f"[WARN] Structural keyword detected: '{warnings[0]}'. Consider: ema proposal create instead.")

    out(f"{tid} | {title} | project: {proj} | status: {status}")


def cmd_task_list(client, args):
    params = {}
    if args.project:
        params["project_id"] = args.project
    if args.status:
        params["status"] = args.status
    if args.limit:
        params["limit"] = args.limit

    result = client.get("/api/tasks", params=params if params else None)
    tasks = result.get("tasks", []) if isinstance(result, dict) else result

    if args.overdue:
        now = datetime.utcnow().isoformat()
        tasks = [t for t in tasks if t.get("due_date") and t["due_date"] < now]

    if USE_JSON:
        out_json(tasks)
        return

    if not tasks:
        out("No tasks found.")
        return

    rows = []
    for t in tasks:
        rows.append([
            t.get("id", "?")[:20],
            (t.get("title") or "")[:35],
            (t.get("project_id") or "—")[:12],
            t.get("status", "?")[:10],
            fmt_priority(t.get("priority")),
            fmt_time(t.get("due_date")) if t.get("due_date") else "—",
        ])
    table(rows, ["ID", "TITLE", "PROJECT", "STATUS", "PRIORITY", "DUE"],
          [22, 36, 14, 11, 9, 12])


def cmd_task_get(client, args):
    result = client.get(f"/api/tasks/{args.task_id}")

    if USE_JSON:
        out_json(result)
        return

    task = result.get("task", result)
    out(f"\nTask: {task.get('id')}")
    out(f"  Title:    {task.get('title')}")
    out(f"  Status:   {task.get('status', '?')}")
    out(f"  Priority: {fmt_priority(task.get('priority'))}")
    out(f"  Project:  {task.get('project_id') or '—'}")
    out(f"  Due:      {task.get('due_date') or '—'}")
    out(f"  Created:  {fmt_time(task.get('created_at') or task.get('inserted_at'))}")
    if task.get("description"):
        out(f"  Desc:     {task['description']}")

    subtasks = result.get("subtasks", [])
    if subtasks:
        out(f"\n  Subtasks ({len(subtasks)}):")
        for s in subtasks:
            out(f"    [{s.get('status','?')}] {s.get('title')}")


def cmd_task_dispatch(client, args):
    """Dispatch a task — routes through OpenClaw via /api/openclaw/dispatch."""
    task_result = client.get(f"/api/tasks/{args.task_id}")
    task = task_result.get("task", task_result)

    if args.dry_run:
        agent = args.agent or "auto"
        out(f"[DRY RUN] Would dispatch task {args.task_id} to agent: {agent}")
        out(f"  Title: {task.get('title')}")
        if args.scope:
            out(f"  Scope: {args.scope}")
        return

    objective = task.get("title", "")
    if args.scope:
        objective += f"\n\nScope constraint: {args.scope}"
    if args.context:
        objective += f"\n\nContext: {args.context}"

    payload = {
        "task_id": args.task_id,
        "objective": objective,
        "mode": "implement",
    }
    if args.agent:
        payload["agent"] = args.agent

    try:
        result = client.post("/api/openclaw/dispatch", payload)
        if USE_JSON:
            out_json(result)
            return
        exec_id = result.get("execution_id") or result.get("id") or "?"
        agent = result.get("agent") or args.agent or "auto"
        out(f"Dispatched {args.task_id} → agent: {agent} | execution: {exec_id}")
    except SystemExit:
        exec_payload = {
            "objective": task.get("title", ""),
            "mode": "implement",
            "task_id": args.task_id,
            "title": task.get("title", ""),
        }
        result = client.post("/api/executions", exec_payload)
        if USE_JSON:
            out_json(result)
            return
        exec_id = result.get("id") or "?"
        out(f"Dispatched {args.task_id} → execution: {exec_id}")


def cmd_task_status(client, args):
    result = client.get(f"/api/tasks/{args.task_id}")
    task = result.get("task", result)

    if USE_JSON:
        out_json(task)
        return

    status = task.get("status", "?")
    created = task.get("created_at") or task.get("inserted_at")
    elapsed = ""
    if created:
        try:
            from datetime import timezone
            dt = datetime.fromisoformat(created.replace("Z", "+00:00"))
            delta = datetime.now(timezone.utc) - dt
            m, s = divmod(int(delta.total_seconds()), 60)
            elapsed = f" | age: {m}m{s}s"
        except Exception:
            pass

    out(f"{args.task_id} | {status}{elapsed} | {task.get('title', '?')}")


# ── project ───────────────────────────────────────────────────────────────────

def cmd_project_create(client, args):
    # API expects flat params; slug is required by the changeset
    slug = args.slug or slugify(args.name)
    payload = {"name": args.name, "slug": slug}
    if args.description:
        payload["description"] = args.description
    if args.path:
        payload["linked_path"] = args.path  # API field is linked_path
    if args.repo:
        payload["repo_url"] = args.repo
    if args.client_name:
        payload["client_name"] = args.client_name

    result = client.post("/api/projects", payload)
    proj = result

    if USE_JSON:
        out_json(proj)
        return

    out(f"{proj.get('id','?')} | {proj.get('name','?')} | slug: {proj.get('slug','?')}")


def cmd_project_list(client, args):
    result = client.get("/api/projects")
    projects = result.get("projects", []) if isinstance(result, dict) else result

    if USE_JSON:
        out_json(projects)
        return

    if not projects:
        out("No projects found.")
        return

    rows = []
    for p in projects:
        rows.append([
            p.get("slug") or p.get("id","?"),
            (p.get("name") or "?")[:20],
            (p.get("status") or "active")[:8],
            fmt_time(p.get("updated_at")),
        ])
    table(rows, ["SLUG", "NAME", "STATUS", "LAST ACTIVE"], [18, 22, 10, 14])


def _find_project(client, slug_or_id):
    """Find a project by slug or ID. Returns the project dict or dies."""
    import io
    # If it looks like an internal ID (contains underscores and digits), try direct first
    if slug_or_id.startswith("proj_"):
        result = client.get(f"/api/projects/{slug_or_id}")
        if result and "id" in result:
            return result
    # For slugs, go straight to list and filter (avoids spurious 404 error output)
    list_result = client.get("/api/projects")
    projects = list_result.get("projects", []) if isinstance(list_result, dict) else list_result
    for p in projects:
        if p.get("slug") == slug_or_id or p.get("id") == slug_or_id:
            return p
    # Last resort: try direct API lookup (for IDs that don't start with proj_)
    try:
        old_stderr = sys.stderr
        sys.stderr = io.StringIO()
        result = client.get(f"/api/projects/{slug_or_id}")
        sys.stderr = old_stderr
        if result and "id" in result:
            return result
    except SystemExit:
        sys.stderr = old_stderr
    die(f"Project not found: {slug_or_id}", exit_code=1)


def cmd_project_view(client, args):
    proj = _find_project(client, args.slug)

    if USE_JSON:
        out_json(proj)
        return

    out(f"\nProject: {proj.get('id')}")
    out(f"  Name:    {proj.get('name')}")
    out(f"  Slug:    {proj.get('slug')}")
    out(f"  Status:  {(proj.get('status') or 'active')}")
    if proj.get("description"):
        out(f"  Desc:    {proj['description'][:80]}")
    if proj.get("linked_path"):
        out(f"  Path:    {proj['linked_path']}")
    out(f"  Created: {fmt_time(proj.get('created_at') or proj.get('inserted_at'))}")


def cmd_project_context(client, args):
    proj = _find_project(client, args.slug)
    result = client.get(f"/api/projects/{proj['id']}/context")

    if USE_JSON:
        out_json(result)
        return

    if args.inject_to:
        Path(args.inject_to).write_text(json.dumps(result, indent=2))
        out(f"Context bundle written to {args.inject_to}")
        return

    out(json.dumps(result, indent=2, default=str))


def cmd_project_deps(client, args):
    proj = _find_project(client, args.slug)

    if USE_JSON:
        out_json(proj)
        return

    out(f"Project: {proj.get('name', args.slug)}")
    try:
        tasks_result = client.get(f"/api/projects/{proj['id']}/tasks")
        tasks = tasks_result.get("tasks", []) if isinstance(tasks_result, dict) else tasks_result
        out(f"  Tasks: {len(tasks)}")
        for t in tasks[:5]:
            out(f"    [{t.get('status','?')}] {t.get('title','?')[:50]}")
        if len(tasks) > 5:
            out(f"    ... and {len(tasks)-5} more")
    except SystemExit:
        out("  Tasks: (unavailable)")
    out("  (Full dependency graph: Phase 2)")


