    out(f"  Name:   {actor.get('name', '—')}")
    out(f"  Slug:   {actor.get('slug', '—')}")
    out(f"  Type:   {actor.get('actor_type', '—')}")
    out(f"  Status: {actor.get('status', '—')}")
    out(f"  Created: {fmt_time(actor.get('inserted_at'))}")


