def cmd_em_retro(client, args):
    result = client.get(f"/api/actors/{args.actor}/phases")

    phases = result.get("phases", []) if isinstance(result, dict) else result
    if args.week:
        phases = [p for p in phases if p.get("week_number") == args.week]

    if USE_JSON:
        out_json(phases)
        return

    if not phases:
        out("No phases found for the given criteria.")
        return
    rows = []
    for p in phases:
        rows.append([
            (p.get("phase") or p.get("name") or "?")[:20],
            str(p.get("week_number", "—"))[:6],
            (p.get("status") or "?")[:12],
            (p.get("reason") or "—")[:30],
        ])
    table(rows, ["PHASE", "WEEK", "STATUS", "REASON"], [22, 8, 14, 32])


# ── actor (CRUD) ────────────────────────────────────────────────────────────

def cmd_actor_list(client, args):
    params = {}
    if args.type:
        params["type"] = args.type
    result = client.get("/api/actors", params=params or None)
    actors = result.get("actors", []) if isinstance(result, dict) else result

    if USE_JSON:
        out_json(actors)
        return

    if not actors:
        out("No actors found.")
        return
    rows = []
    for a in actors:
        rows.append([
            a.get("slug", "?")[:16],
            (a.get("name") or "?")[:25],
            (a.get("actor_type") or "?")[:12],
            (a.get("status") or "?")[:10],
        ])
    table(rows, ["SLUG", "NAME", "TYPE", "STATUS"], [18, 27, 14, 11])


