    payload = {"name": args.name, "slug": args.slug, "actor_type": args.type}
    result = client.post("/api/actors", payload)

    if USE_JSON:
        out_json(result)
        return

    actor = result.get("actor", result)
    out(f"{actor.get('id', '?')} | {actor.get('name', '?')} | type: {actor.get('actor_type', '?')}")


def cmd_actor_get(client, args):
