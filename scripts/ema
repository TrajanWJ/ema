def cmd_data_delete(client, args):
    entity_type, entity_id = _split_entity_ref(args.entity_ref)
    params = {
        "entity_type": entity_type,
        "entity_id": entity_id,
        "actor_id": args.actor,
        "key": args.key,
    }
    result = client.request("DELETE", "/api/entity-data", params=params)

    if USE_JSON:
        out_json(result)
        return

    out(f"Deleted {args.entity_ref} [{args.key}]")


def cmd_focus_start(client, args):
    payload = {}
    if args.duration:
        payload["target_ms"] = args.duration * 60 * 1000
    if args.task:
        payload["task_id"] = args.task
    result = client.post("/api/focus/start", payload)
    if USE_JSON:
        out_json(result)
        return
    session = result.get("session", result)
    out(f"Focus started: {session.get('id', '?')}")
    if args.duration:
        out(f"  Duration: {args.duration}m")


def cmd_focus_stop(client, args):
