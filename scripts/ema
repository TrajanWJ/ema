# ── watch (live dashboard) ───────────────────────────────────────────────────

import time


def cmd_watch(client, args):
    """Live dashboard — polls EMA and displays updates. Ctrl+C to exit."""
    interval = args.interval or 10
    channel = args.channel or "all"

    def fetch_section(path, fallback="unavailable"):
        try:
            return client.get(path)
        except (SystemExit, Exception):
            return None

    def render():
        lines = []
        from datetime import timezone
        now = datetime.now(timezone.utc).strftime("%H:%M:%S UTC")
        lines.append(f"\033[1mEMA Live — {now} — every {interval}s — [{channel}]\033[0m")
        lines.append("─" * 64)

        if channel in ("all", "heartbeat"):
            data = fetch_section("/api/health")
            if data:
                lines.append(f"\033[36m[heartbeat]\033[0m {data.get('status', 'ok')}")
            else:
                lines.append(f"\033[36m[heartbeat]\033[0m \033[31moffline\033[0m")

        if channel in ("all", "pipeline", "executions"):
            data = fetch_section("/api/executions")
            execs = (data.get("executions", []) if data else [])[:7]
            lines.append(f"\n\033[36m[pipeline]\033[0m {len(execs)} recent executions")
            for e in execs:
                s = e.get("status", "?")
                icon = {"completed": "\033[32m✓", "running": "\033[33m▶", "failed": "\033[31m✗"}.get(s, "\033[0m·")
                title = (e.get("title") or e.get("objective", "?"))[:42]
                lines.append(f"  {icon} {s:<10}\033[0m {title}  {fmt_time(e.get('inserted_at'))}")

        if channel in ("all", "tasks"):
            data = fetch_section("/api/tasks")
            tasks = data.get("tasks", []) if data else []
            running = [t for t in tasks if t.get("status") == "running"]
            pending = [t for t in tasks if t.get("status") in ("todo", "pending", "created")]
            lines.append(f"\n\033[36m[tasks]\033[0m {len(running)} running, {len(pending)} pending")
            for t in running[:3]:
                lines.append(f"  ▶ {(t.get('title') or '?')[:55]}")
            for t in pending[:2]:
                lines.append(f"  ○ {(t.get('title') or '?')[:55]}")

        if channel in ("all", "proposals"):
            data = fetch_section("/api/proposals")
            props = data.get("proposals", []) if data else []
            queued = [p for p in props if p.get("status") in ("queued", "pending", "generating")]
            lines.append(f"\n\033[36m[proposals]\033[0m {len(queued)} queued, {len(props)} total")
            for p in queued[:3]:
                lines.append(f"  ◆ {(p.get('title') or '?')[:55]}")

        if channel in ("all", "agents"):
            data = fetch_section("/api/agents")
            agents = data.get("agents", []) if data else []
            lines.append(f"\n\033[36m[agents]\033[0m {len(agents)} configured")
            for a in agents[:5]:
                lines.append(f"  • {a.get('slug','?'):<16} {(a.get('model') or 'default'):<18} {a.get('status', 'active')}")

        if channel in ("all", "braindump", "inbox"):
            data = fetch_section("/api/brain-dump/items")
            items = data.get("items", []) if data else []
            unprocessed = [i for i in items if i.get("status") != "processed"]
            lines.append(f"\n\033[36m[brain-dump]\033[0m {len(unprocessed)} unprocessed")
            for i in unprocessed[:3]:
                lines.append(f"  ▸ {(i.get('content') or '?')[:55]}  {fmt_time(i.get('inserted_at'))}")

        if channel in ("all", "focus"):
            data = fetch_section("/api/focus/current")
            if data and data.get("session", {}).get("id"):
                s = data["session"]
                lines.append(f"\n\033[36m[focus]\033[0m Active: {s.get('status','?')}")
            else:
                lines.append(f"\n\033[36m[focus]\033[0m No active session")

        if channel in ("all", "babysitter"):
            data = fetch_section("/api/babysitter/state")
            if data:
                state = data.get("state", data)
                summary = str(state)[:80] if not isinstance(state, dict) else ", ".join(f"{k}={v}" for k, v in list(state.items())[:4])
                lines.append(f"\n\033[36m[babysitter]\033[0m {summary[:60]}")

        if channel in ("all", "tokens", "cost"):
            data = fetch_section("/api/tokens/budget")
            if data:
                used = data.get("used_today") or data.get("tokens_today", "—")
                limit = data.get("daily_limit") or data.get("budget", "—")
                cost = data.get("cost_today") or data.get("cost_usd", "—")
                lines.append(f"\n\033[36m[tokens]\033[0m used: {used} | limit: {limit} | cost: ${cost}")

        lines.append(f"\n\033[2mCtrl+C to exit\033[0m")
        return "\n".join(lines)

    try:
        while True:
            output = render()
            sys.stdout.write("\033[2J\033[H")
            sys.stdout.write(output + "\n")
            sys.stdout.flush()
            time.sleep(interval)
    except KeyboardInterrupt:
        sys.stdout.write("\033[2J\033[H")
        out("Watch stopped.")


# ─── Arg parsing ──────────────────────────────────────────────────────────────

def build_parser():
    shared = argparse.ArgumentParser(add_help=False)
    shared.add_argument("--host", "-H", default=None, help="Daemon URL (default: localhost:4488)")
    shared.add_argument("--json", "-j", action="store_true", help="Output raw JSON")
    shared.add_argument("--quiet", "-q", action="store_true", help="Suppress non-error output")
    shared.add_argument("--verbose", "-v", action="store_true", help="Show request details")

    p = argparse.ArgumentParser(
        prog="ema",
        description="EMA CLI — terminal client for the EMA daemon",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        parents=[shared],
        epilog="""
Commands:
  ema dump "thought"                   Quick brain dump
  ema mcp tools|resources|read|call|doctor|config|stdio
  ema task create|list|get|dispatch|status
  ema project create|list|view|context|dependencies
  ema proposal list|view|dispatch
  ema exec list|get|create|approve|cancel|diff
  ema agent list|get|chat|conversations
  ema goal list|create|get|update
  ema brain-dump create|list|process|delete
  ema focus start|stop|pause|resume|current|today
  ema habit list|create|toggle|today|archive
  ema journal read|write|search
  ema provider list|status
  ema tokens summary|budget
  ema vault search
  ema watch [--channel heartbeat|pipeline|tasks|...]
  ema dispatch status|logs
  ema health check
  ema sync openclaw
  ema status

Examples:
  ema dump "investigate auth token expiry"
  ema mcp tools
  ema mcp read 'ema://context/project?id=ema'
  ema mcp call ema_spawn_session --arg prompt='Investigate build drift' --arg project_slug=ema
  ema agent chat main "what should I work on?"
  ema exec list --status running
  ema exec create "research auth patterns" --mode research
  ema watch --interval 5 --channel pipeline
  ema focus start --duration 25 --task <id>
  ema journal write "Shipped the auth refactor" --mood good
  ema habit today
  ema goal create "Ship EMA v2" --description "Full CLI + TUI"
  ema provider list
  ema task create "Fix auth module" --project proslync
  ema status
        """
    )

    p.add_argument("--version", action="version", version="ema 2.0.0")

    sub = p.add_subparsers(dest="group", metavar="COMMAND")

    # ── task ──
    task_p = sub.add_parser("task", help="Task management", parents=[shared])
    task_sub = task_p.add_subparsers(dest="action", metavar="ACTION")

    tc = task_sub.add_parser("create", help="Create a task")
    tc.add_argument("title", help="Task title")
    tc.add_argument("--project", "-p", help="Project id or slug")
    tc.add_argument("--priority", type=int, choices=[1,2,3,4,5], help="Priority 1=critical 5=minimal")
    tc.add_argument("--due", help="Due date (ISO8601)")
    tc.add_argument("--description", help="Task description")
    tc.add_argument("--status", default="todo", help="Initial status (default: todo)")

    tl = task_sub.add_parser("list", help="List tasks")
    tl.add_argument("--project", "-p", help="Filter by project")
    tl.add_argument("--status", "-s", help="Filter by status")
    tl.add_argument("--overdue", action="store_true", help="Only overdue tasks")
    tl.add_argument("--limit", "-n", type=int, help="Max results")

    tg = task_sub.add_parser("get", help="Get task details")
    tg.add_argument("task_id", help="Task ID")

    td = task_sub.add_parser("dispatch", help="Dispatch a task to an agent")
    td.add_argument("task_id", help="Task ID")
    td.add_argument("--agent", "-a", help="Override agent")
    td.add_argument("--scope", help="Scope constraint")
    td.add_argument("--context", "-c", help="Additional context")
    td.add_argument("--dry-run", action="store_true", help="Show what would run without executing")

    ts = task_sub.add_parser("status", help="Get task status")
    ts.add_argument("task_id", help="Task ID")

    # ── project ──
    proj_p = sub.add_parser("project", help="Project management", parents=[shared])
