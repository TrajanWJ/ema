    return p


# ─── Main ─────────────────────────────────────────────────────────────────────

def main():
    global USE_JSON, QUIET

    # Pre-scan argv for global flags that may appear after subcommand
    _argv = sys.argv[1:]
    _use_json = "--json" in _argv or "-j" in _argv
    _quiet = "--quiet" in _argv or "-q" in _argv

    # Strip global flags to prevent "unrecognized" errors when after subcommand
    _clean = [a for a in _argv if a not in ("--json", "-j", "--quiet", "-q")]
    sys.argv = [sys.argv[0]] + _clean

    parser = build_parser()
    args = parser.parse_args()

    USE_JSON = _use_json
    QUIET = _quiet
    args.json = _use_json
    args.quiet = _quiet

    # Resolve host
    host = (
        (args.host if hasattr(args, "host") and args.host else None)
        or CONFIG.get("host")
        or os.environ.get("EMA_HOST")
        or DEFAULT_HOST
    )

    verbose = args.verbose if hasattr(args, "verbose") else False
    client = EMAClient(host, verbose=verbose)

    if not args.group:
        parser.print_help()
        sys.exit(0)

    # ── Route ──
    if args.group == "status":
        cmd_status(client, args)

    elif args.group == "task":
        if not args.action:
            parser.parse_args(["task", "--help"])
        elif args.action == "create":
            cmd_task_create(client, args)
        elif args.action == "list":
            cmd_task_list(client, args)
        elif args.action == "get":
            cmd_task_get(client, args)
        elif args.action == "dispatch":
            cmd_task_dispatch(client, args)
        elif args.action == "status":
            cmd_task_status(client, args)

    elif args.group == "project":
        if not args.action:
            parser.parse_args(["project", "--help"])
        elif args.action == "create":
            cmd_project_create(client, args)
        elif args.action == "list":
            cmd_project_list(client, args)
        elif args.action == "view":
            cmd_project_view(client, args)
        elif args.action == "context":
            cmd_project_context(client, args)
        elif args.action == "dependencies":
            cmd_project_deps(client, args)

    elif args.group == "proposal":
        if not args.action:
            parser.parse_args(["proposal", "--help"])
        elif args.action == "list":
            cmd_proposal_list(client, args)
        elif args.action == "view":
            cmd_proposal_view(client, args)
        elif args.action == "dispatch":
            cmd_proposal_dispatch(client, args)

    elif args.group == "vault":
        if not args.action:
            parser.parse_args(["vault", "--help"])
        elif args.action == "search":
            cmd_vault_search(client, args)

    elif args.group == "health":
        if not hasattr(args, 'action') or not args.action or args.action == "check":
            cmd_health_check(client, args)

    elif args.group == "dispatch":
        if not args.action:
            parser.parse_args(["dispatch", "--help"])
        elif args.action == "status":
            cmd_dispatch_status(client, args)
        elif args.action == "logs":
            cmd_dispatch_logs(client, args)

    elif args.group == "sync":
        if not args.action:
            parser.parse_args(["sync", "--help"])
        elif args.action == "openclaw":
            cmd_sync_openclaw(client, args)

    elif args.group == "dump":
        cmd_dump(client, args)

    elif args.group == "mcp":
        if not args.action:
            parser.parse_args(["mcp", "--help"])
        elif args.action == "tools":
            cmd_mcp_tools(client, args)
        elif args.action == "resources":
            cmd_mcp_resources(client, args)
        elif args.action == "read":
            cmd_mcp_read(client, args)
        elif args.action == "call":
            cmd_mcp_call(client, args)
        elif args.action == "doctor":
            cmd_mcp_doctor(client, args)
        elif args.action == "config":
            cmd_mcp_config(client, args)
        elif args.action == "stdio":
            cmd_mcp_stdio(client, args)

    elif args.group == "brain-dump":
        if not args.action:
            parser.parse_args(["brain-dump", "--help"])
        elif args.action == "create":
            cmd_braindump_create(client, args)
        elif args.action == "list":
            cmd_braindump_list(client, args)
        elif args.action == "process":
            cmd_braindump_process(client, args)
        elif args.action == "delete":
            cmd_braindump_delete(client, args)

    elif args.group == "goal":
        if not args.action:
            parser.parse_args(["goal", "--help"])
        elif args.action == "list":
            cmd_goal_list(client, args)
        elif args.action == "create":
            cmd_goal_create(client, args)
        elif args.action == "get":
            cmd_goal_get(client, args)
        elif args.action == "update":
            cmd_goal_update(client, args)

    elif args.group == "agent":
        if not args.action:
            parser.parse_args(["agent", "--help"])
        elif args.action == "list":
            cmd_agent_list(client, args)
        elif args.action == "get":
            cmd_agent_get(client, args)
        elif args.action == "chat":
            cmd_agent_chat(client, args)
        elif args.action == "conversations":
            cmd_agent_conversations(client, args)

    elif args.group == "exec":
        if not args.action:
            parser.parse_args(["exec", "--help"])
        elif args.action == "list":
            cmd_exec_list(client, args)
        elif args.action == "get":
            cmd_exec_get(client, args)
        elif args.action == "create":
            cmd_exec_create(client, args)
        elif args.action == "approve":
            cmd_exec_approve(client, args)
        elif args.action == "cancel":
            cmd_exec_cancel(client, args)
        elif args.action == "diff":
            cmd_exec_diff(client, args)

    elif args.group == "focus":
        if not args.action:
            parser.parse_args(["focus", "--help"])
        elif args.action == "start":
            cmd_focus_start(client, args)
        elif args.action == "stop":
            cmd_focus_stop(client, args)
        elif args.action == "pause":
            cmd_focus_pause(client, args)
        elif args.action == "resume":
            cmd_focus_resume(client, args)
        elif args.action == "current":
            cmd_focus_current(client, args)
        elif args.action == "today":
            cmd_focus_today(client, args)

    elif args.group == "habit":
        if not args.action:
            parser.parse_args(["habit", "--help"])
        elif args.action == "list":
            cmd_habit_list(client, args)
        elif args.action == "create":
            cmd_habit_create(client, args)
        elif args.action == "toggle":
            cmd_habit_toggle(client, args)
        elif args.action == "today":
            cmd_habit_today(client, args)
        elif args.action == "archive":
            cmd_habit_archive(client, args)

    elif args.group == "journal":
        if not args.action:
            parser.parse_args(["journal", "--help"])
        elif args.action == "read":
            cmd_journal_read(client, args)
        elif args.action == "write":
            cmd_journal_write(client, args)
        elif args.action == "search":
            cmd_journal_search(client, args)

    elif args.group == "provider":
        if not args.action:
            cmd_provider_list(client, args)
        elif args.action == "list":
            cmd_provider_list(client, args)
        elif args.action == "status":
            cmd_provider_status(client, args)

    elif args.group == "tokens":
        if not args.action:
            cmd_tokens_summary(client, args)
        elif args.action == "summary":
            cmd_tokens_summary(client, args)
        elif args.action == "budget":
            cmd_tokens_budget(client, args)

    elif args.group == "em":
        if not args.action:
            parser.parse_args(["em", "--help"])
        elif args.action == "status":
            cmd_em_status(client, args)
        elif args.action == "phases":
            cmd_em_phases(client, args)
        elif args.action == "velocity":
            cmd_em_velocity(client, args)
        elif args.action == "advance":
            cmd_em_advance(client, args)
        elif args.action == "retro":
            cmd_em_retro(client, args)

    elif args.group == "actor":
        if not args.action:
            parser.parse_args(["actor", "--help"])
        elif args.action == "list":
            cmd_actor_list(client, args)
        elif args.action == "create":
            cmd_actor_create(client, args)
        elif args.action == "get":
            cmd_actor_get(client, args)

    elif args.group == "tag":
        if not args.action:
            parser.parse_args(["tag", "--help"])
        elif args.action == "add":
            cmd_tag_add(client, args)
        elif args.action == "list":
            cmd_tag_list(client, args)
        elif args.action == "remove":
            cmd_tag_remove(client, args)

    elif args.group == "data":
        if not args.action:
            parser.parse_args(["data", "--help"])
        elif args.action == "get":
            cmd_data_get(client, args)
        elif args.action == "set":
            cmd_data_set(client, args)
        elif args.action == "list":
            cmd_data_list(client, args)
        elif args.action == "delete":
            cmd_data_delete(client, args)

    elif args.group == "watch":
        cmd_watch(client, args)


if __name__ == "__main__":
    main()
